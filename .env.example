# JWT signing secret (required in production; dev uses a hardcoded fallback)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Optional registration invite code (leave blank for open registration)
REGISTRATION_CODE=

# Comma-separated admin email addresses (case-insensitive)
ADMIN_EMAILS=

# Resend API key for sending verification emails (https://resend.com)
RESEND_API_KEY=

# Public URL of the app — used for verification link generation
APP_URL=http://localhost:3000

# Directory for the vault database (defaults to "data" if unset).
# On Render/Railway, leave this unset so the platform volume path is used.
FORGE_VAULT_DIR=data

# Optional backup destination. Use a different persistent volume or mounted
# storage location from FORGE_VAULT_DIR for disaster recovery.
FORGE_BACKUP_DIR=

# Async PDF-import jobs with OCR support. Leave enabled: without it the
# client falls back to the legacy synchronous analyzer, which times out on
# scanned sheets.
PDF_IMPORT_OCR_ENABLED=true

# Set to true to skip email verification entirely (auto-verify at signup and
# never block login). For local/self-hosted servers — leave unset in
# production so real verification emails are required.
DISABLE_EMAIL_VERIFICATION=true
