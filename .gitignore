# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/.tmp/
/.npm-cache/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# environment variables
.env
.env*.local

# user vault data — contains password hashes and character data
data/forge-vault.json
data/forge-vault-backup-*.json

# TypeScript build info
*.tsbuildinfo

# misc
Thumbs.db
*.swp
*.swo
.pnpm-debug.log*
dev-server.log
dev-server.err.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local prototype data
/data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


# transient dev/audit logs (kept locally, never committed)
audit-dev.*.log
dev-server.log
dev-server.err.log
tmp/*.log
.codex-*.log

# backup directories
.portrait-module-backup/
.codex-vault-test/

# temp/scratch directory
/tmp/
*.md
