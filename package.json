{
  "name": "dreamwright",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:ci": "eslint --max-warnings=0",
    "test": "vitest run --no-file-parallelism",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "assets:check": "node scripts/check-release-assets.mjs",
    "bundle:check": "node scripts/check-bundle-budget.mjs",
    "rules:validate-research": "node scripts/rules/validate-research.mjs",
    "rules:build-actions": "node scripts/build-action-capability-data.mjs",
    "portraits:sync": "python scripts/sync-portraits.py",
    "db:backup": "node scripts/backup-db.mjs",
    "db:verify-backup": "node scripts/verify-db-backup.mjs",
    "db:restore-drill": "node scripts/drill-db-restore.mjs",
    "cleanup:pdf-imports": "node scripts/clean-pdf-imports.mjs",
    "fixtures:pdf-import": "node scripts/generate-pdf-fixtures.mjs",
    "release:check": "npm run rules:validate-research && npm run assets:check && npm test && npm run lint:ci && npm run typecheck && npm run build && npm run bundle:check && npm audit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@napi-rs/canvas": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "pdfjs-dist": "^4.10.38",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.2",
    "tesseract.js": "^7.0.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "typescript": "^5",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
